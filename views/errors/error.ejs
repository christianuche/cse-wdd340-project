<div class="error-wrapper notice" style="margin-top: 40px; padding: 30px; border-radius: 8px; text-align: center; background-color: #fdf2f2; border: 1px solid #d9534f;">
    
    <img src="/images/error-img/funny-404-error-page-nasa-1024x691.webp" alt="Lost in Space Error" style="width: 100%; max-width: 500px; height: auto; border-radius: 8px; margin-bottom: 20px; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">

    <h1 style="color: #c9302c; font-size: 2.5rem; margin-bottom: 20px;">
        <%= typeof title !== 'undefined' ? title : 'Server Error' %>
    </h1>

    <div class="error-message" style="font-size: 1.25rem; color: #333; margin-bottom: 30px;">
        <% if (typeof message !== 'undefined') { %>
            <p><%= message %></p>
        <% } else { %>
            <p>We're sorry, but an unexpected error occurred while processing your request.</p>
        <% } %>
    </div>

    <% if (typeof messages === 'function') { %>
        <%- messages() %>
    <% } %>

    <p style="margin-top: 20px;">
        <a href="/" title="Return to Home" style="display: inline-block; padding: 10px 20px; background-color: var(--bg-dark); color: #fff; text-decoration: none; border-radius: 4px; font-weight: bold; transition: background-color 0.3s ease;">
            &larr; Return to Home
        </a>
    </p>
</div>