<div class="login-container inventory-container">
  <h1>
    <%= title %>
  </h1>

  <%- messages() %>

  <p class="required-notice">ALL FIELDS ARE REQUIRED.</p>

    <% if (errors) { %>
      <ul class="notice">
        <% errors.array().forEach(error=> { %>
          <li>
            <%= error.msg %>
          </li>
          <% }) %>
      </ul>
      <% } %>

        <form id="editInventoryForm" class="login-form" action="/inv/update" method="POST">
          <div class="form-group">
            <label for="classificationList" class="form-label">Classification</label>
            <%- classificationSelect %>
          </div>

          <div class="form-group">
            <label for="inv_make" class="form-label">Make</label>
            <input type="text" id="inv_make" name="inv_make" class="form-input" required 
              placeholder="Min 3 characters" minlength="3" value="<%= locals.inv_make %>">
          </div>

          <div class="form-group">
            <label for="inv_model" class="form-label">Model</label>
            <input type="text" id="inv_model" name="inv_model" class="form-input" required
              placeholder="Min 3 characters" minlength="3" value="<%= locals.inv_model %>">
          </div>

          <div class="form-group">
            <label for="inv_year" class="form-label">Year</label>
            <input type="number" id="inv_year" name="inv_year" class="form-input" required 
              placeholder="4-digit year" min="1000" max="9999" value="<%= locals.inv_year %>">
          </div>

          <div class="form-group">
            <label for="inv_description" class="form-label">Description</label>
            <textarea id="inv_description" name="inv_description" class="form-input" required
              placeholder="Enter description"><%= locals.inv_description %></textarea>
          </div>

          <div class="form-group">
            <label for="inv_image" class="form-label">Image Path</label>
            <input type="text" id="inv_image" name="inv_image" class="form-input" required
              value="<%= locals.inv_image || '/images/vehicles/no-image.png' %>">
          </div>

          <div class="form-group">
            <label for="inv_thumbnail" class="form-label">Thumbnail Path</label>
            <input type="text" id="inv_thumbnail" name="inv_thumbnail" class="form-input" required
              value="<%= locals.inv_thumbnail || '/images/vehicles/no-image-tn.png' %>">
          </div>

          <div class="form-group">
            <label for="inv_price" class="form-label">Price</label>
            <input type="number" id="inv_price" name="inv_price" class="form-input" required step="0.01"
              placeholder="decimal or integer" value="<%= locals.inv_price %>">
          </div>

          <div class="form-group">
            <label for="inv_miles" class="form-label">Miles</label>
            <input type="number" id="inv_miles" name="inv_miles" class="form-input" required placeholder="Digit only"
              value="<%= locals.inv_miles %>">
          </div>

          <div class="form-group">
            <label for="inv_color" class="form-label">Color</label>
            <input type="text" id="inv_color" name="inv_color" class="form-input" required placeholder="Enter color"
              value="<%= locals.inv_color %>">
          </div>

          <button type="submit" class="submit-btn primary-btn">Update Vehicle</button>
          <input type="hidden" name="inv_id"
          <% if(locals.inv_id) { %> value="<%= locals.inv_id %>"
          <% } %>>
        </form>
</div>
