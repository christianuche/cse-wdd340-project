<div class="inventory-search-page">
  <div class="inventory-header">
    <h1><%= title %></h1>
  </div>

  <%- messages() %>

  <div class="inventory-section search-panel">
    <h2>Inventory Search</h2>
    <p>Search for vehicles by make or model, or filter by classification.</p>

    <% if (errors) { %>
      <ul class="notice-list">
        <% errors.array().forEach(error => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    <% } %>

    <form action="/inv/search/results" method="GET" class="search-form">
      <div class="form-grid">
        <div class="form-group">
          <label for="query" class="form-label">Search Term</label>
          <input type="text" id="query" name="query" class="form-input" placeholder="Enter make or model" value="<%= query || '' %>">
        </div>

        <div class="form-group">
          <label for="classificationList" class="form-label">Classification</label>
          <%- classificationSelect %>
        </div>
      </div>

      <div class="button-row">
        <button type="submit" class="submit-btn primary-btn">Search Inventory</button>
      </div>
    </form>
  </div>

  <% if (results !== null) { %>
    <div class="inventory-section search-results">
      <h2>Search Results</h2>
      <% if (results.length > 0) { %>
        <table class="search-results-table">
          <thead>
            <tr>
              <th>Vehicle</th>
              <th>Year</th>
              <th>Classification</th>
              <th>Price</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% results.forEach(vehicle => { %>
              <tr>
                <td><%= vehicle.inv_make %> <%= vehicle.inv_model %></td>
                <td><%= vehicle.inv_year %></td>
                <td><%= vehicle.classification_name %></td>
                <td>$<%= new Intl.NumberFormat('en-US').format(vehicle.inv_price) %></td>
                <td>
                  <a href="/inv/detail/<%= vehicle.inv_id %>">View</a>
                  <a href="/inv/edit/<%= vehicle.inv_id %>">Modify</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p class="notice">No vehicles matched your search criteria.</p>
      <% } %>
    </div>
  <% } %>
</div>
